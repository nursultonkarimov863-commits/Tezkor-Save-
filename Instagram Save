# ---------------------------------------------------------------------------
# yt-dlp yordamchi funksiyalari
# ---------------------------------------------------------------------------

def _download_sync(url: str, out_dir: str, audio_only: bool = False) -> str:
    """Sinxron yuklab olish (thread ichida chaqiriladi)."""
    filename_template = os.path.join(out_dir, f"{uuid.uuid4().hex}.%(ext)s")

    ydl_opts = {
        "outtmpl": filename_template,
        "quiet": True,
        "no_warnings": True,
        "noplaylist": True,
        "max_filesize": MAX_FILE_SIZE_MB * 1024 * 1024,
    }

    if audio_only:
        ydl_opts.update(
            {
                "format": "bestaudio/best",
                "postprocessors": [
                    {
                        "key": "FFmpegExtractAudio",
                        "preferredcodec": "mp3",
                        "preferredquality": "192",
                    }
                ],
            }
        )
    else:
        ydl_opts["format"] = (
            "bestvideo[ext=mp4][filesize<%dM]+bestaudio[ext=m4a]/best[ext=mp4][filesize<%dM]/best"
            % (MAX_FILE_SIZE_MB, MAX_FILE_SIZE_MB)
        )
        ydl_opts["merge_output_format"] = "mp4"

    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        info = ydl.extract_info(url, download=True)
        # yt-dlp audio konvertatsiyadan keyin kengaytmani o'zgartiradi
        filepath = ydl.prepare_filename(info)
        if audio_only:
            filepath = os.path.splitext(filepath)[0] + ".mp3"
        return filepath, info


def _search_sync(query: str, out_dir: str) -> tuple:
    """YouTube'dan qo'shiq qidirib, birinchi natijani mp3 qilib yuklaydi."""
    return _download_sync(f"ytsearch1:{query}", out_dir, audio_only=True)


# ---------------------------------------------------------------------------
# Video link handler
# ---------------------------------------------------------------------------

async def handle_link(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await require_subscription(update, context):
        return

    text = update.message.text or ""
    match = URL_PATTERN.search(text)
    if not match:
        await update.message.reply_text(
            "🤔 Bu Instagram, TikTok yoki YouTube havolasiga o'xshamayapti.\n"
            "To'g'ri havola yuboring yoki musiqa uchun /music dan foydalaning."
        )
        return

    url = match.group(1)
    status_msg = await update.message.reply_text("⏳ Yuklanmoqda, biroz kuting...")

    with tempfile.TemporaryDirectory() as tmp_dir:
        try:
            filepath, info = await asyncio.to_thread(_download_sync, url, tmp_dir, False)

            if not os.path.exists(filepath):
                raise FileNotFoundError("Fayl topilmadi")

            size_mb = os.path.getsize(filepath) / (1024 * 1024)
            if size_mb > MAX_FILE_SIZE_MB:
                await status_msg.edit_text(
                    f"❌ Video hajmi juda katta ({size_mb:.1f} MB). "
                    f"Bot faqat {MAX_FILE_SIZE_MB} MB gacha yubora oladi."
                )
                return

            title = (info.get("title") or "Video")[:1024]
            with open(filepath, "rb") as video_file:
                await update.message.reply_video(
                    video=video_file,
                    caption=f"🎬 {title}",
                    supports_streaming=True,
                )
            await status_msg.delete()

        except yt_dlp.utils.DownloadError as e:
            logger.error("Download xatosi: %s", e)
            await status_msg.edit_text(
                "❌ Video yuklab bo'lmadi. Havola noto'g'ri, video o'chirilgan "
                "yoki xususiy (private) bo'lishi mumkin."
            )
        except Exception as e:
            logger.exception("Kutilmagan xato: %s", e)
            await status_msg.edit_text("❌ Xatolik yuz berdi. Birozdan so'ng qayta urinib ko'ring.")


# ---------------------------------------------------------------------------
# /music handler
# ---------------------------------------------------------------------------

async def music_search(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await require_subscription(update, context):
        return

    if not context.args:
        await update.message.reply_text(
            "🎵 Qo'shiq nomini yozing.\nMasalan: /music Ummon guruhi - Sevgi"
        )
        return

    query = " ".join(context.args)
    status_msg = await update.message.reply_text(f"🔎 \"{query}\" qidirilmoqda...")

    with tempfile.TemporaryDirectory() as tmp_dir:
        try:
            filepath, info = await asyncio.to_thread(_search_sync, query, tmp_dir)

            if not os.path.exists(filepath):
                raise FileNotFoundError("Fayl topilmadi")

            size_mb = os.path.getsize(filepath) / (1024 * 1024)
            if size_mb > MAX_FILE_SIZE_MB:
                await status_msg.edit_text(f"❌ Fayl juda katta ({size_mb:.1f} MB).")
                return

            title = info.get("title") or query
            artist = info.get("uploader") or "Noma'lum"
            with open(filepath, "rb") as audio_file:
                await update.message.reply_audio(
                    audio=audio_file,
                    title=title[:64],
                    performer=artist[:64],
                    caption=f"🎧 {title}",
                )
            await status_msg.delete()

        except yt_dlp.utils.DownloadError as e:
            logger.error("Qidiruv xatosi: %s", e)
            await status_msg.edit_text("❌ Qo'shiq topilmadi. Boshqa nom bilan urinib ko'ring.")
        except Exception as e:
            logger.exception("Kutilmagan xato: %s", e)
            await status_msg.edit_text("❌ Xatolik yuz berdi. Birozdan so'ng qayta urinib ko'ring.")


